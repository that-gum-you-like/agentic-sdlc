{
  "description": "Recommended automated iteration cycle schedules for the agentic SDLC framework.",
  "schedules": [
    {
      "name": "daily-review",
      "cron": "0 6 * * *",
      "script": "node ~/agentic-sdlc/agents/cycles/daily-review.mjs",
      "description": "End-of-day summary, dashboard update, cost logging",
      "session": "isolated"
    },
    {
      "name": "daily-cost-report",
      "cron": "0 7 * * *",
      "script": "node ~/agentic-sdlc/agents/cost-tracker.mjs report",
      "description": "Daily token usage and session hours report",
      "session": "isolated"
    },
    {
      "name": "weekly-pattern-hunt",
      "cron": "0 23 * * 0",
      "script": "node ~/agentic-sdlc/agents/cycles/weekly-review.mjs",
      "description": "Pattern review, REM sleep consolidation, behavior tests",
      "session": "isolated"
    },
    {
      "name": "monthly-behavior-audit",
      "cron": "0 6 1 * *",
      "script": "node ~/agentic-sdlc/agents/cycles/monthly-review.mjs",
      "description": "Monthly cycle: behavior audit + drift, agent version snapshot, memory-migration check, compost cleanup, cost review",
      "session": "isolated"
    },
    {
      "name": "backlog-review",
      "cron": "0 9 * * *",
      "script": "node ~/agentic-sdlc/agents/cycles/daily-review.mjs",
      "description": "Scan openspec changes for orphaned items, verify agents have assigned tasks, flag stale changes >14 days",
      "session": "isolated"
    },
    {
      "name": "orchestration-sync",
      "cron": "17 */6 * * *",
      "script": "node ~/agentic-sdlc/agents/paperclip-sync.mjs --status",
      "description": "Sync SDLC agent config to orchestration platform. Uses paperclip-sync.mjs when Paperclip adapter is configured; skip if using file-based adapter.",
      "session": "isolated",
      "adapterRequired": "paperclip"
    },
    {
      "name": "model-manager-check",
      "cron": "*/15 * * * *",
      "script": "node ~/agentic-sdlc/agents/model-manager.mjs check",
      "description": "Monitor agent token utilization, perform model swaps on budget exhaustion, log to performance ledger",
      "session": "isolated"
    },
    {
      "name": "dependency-audit",
      "cron": "0 8 * * *",
      "script": "node ~/agentic-sdlc/agents/queue-drainer.mjs run --agent dependency-auditor",
      "description": "Daily dependency audit \u2014 scan for CVEs, license violations, version drift, deprecated packages",
      "session": "isolated",
      "agentRequired": "dependency-auditor"
    },
    {
      "name": "performance-check",
      "cron": "0 */4 * * *",
      "script": "node ~/agentic-sdlc/agents/queue-drainer.mjs run --agent performance-sentinel",
      "description": "Periodic performance benchmark \u2014 check bundle size, API latency, test duration against baselines",
      "session": "isolated",
      "agentRequired": "performance-sentinel"
    },
    {
      "name": "health-check-daily",
      "cron": "0 6 * * *",
      "script": "node ~/agentic-sdlc/agents/health-check.mjs --notify",
      "description": "Autonomous health check \u2014 queue depth, per-agent budget headroom, disk free, cron liveness; notify on non-ok",
      "session": "isolated"
    },
    {
      "name": "red-team-weekly",
      "cron": "0 22 * * 0",
      "script": "node ~/agentic-sdlc/agents/red-team-tester.mjs --notify",
      "description": "Weekly adversarial scan of agent outputs / prompts for injection, exfiltration, tool-abuse, jailbreak markers; notify on high severity",
      "session": "isolated"
    },
    {
      "name": "rag-index-weekly",
      "cron": "30 23 * * 0",
      "script": "node ~/agentic-sdlc/agents/rag-indexer.mjs",
      "description": "Weekly rebuild of the local semantic index over docs/openspec/memory (local embeddings, lexical fallback)",
      "session": "isolated"
    },
    {
      "name": "doc-sync-daily",
      "cron": "15 6 * * *",
      "script": "node ~/agentic-sdlc/agents/document-sync.mjs",
      "description": "Daily content-hash + version knowledge docs; mark changed docs for re-indexing by rag-indexer",
      "session": "isolated"
    },
    {
      "name": "autonomous-drain",
      "cron": "*/15 * * * *",
      "script": "~/agentic-sdlc/agents/hermes-drain.sh",
      "description": "Autonomous backlog drain via isolated local-backend Hermes (OpenRouter affordable models). No-op unless the repo is idle on main with a clean tree AND a task is ready; then runs one task \u2192 branch \u2192 tests \u2192 PR for human review. Never touches main.",
      "session": "isolated"
    },
    {
      "name": "kanban-sync",
      "cron": "*/15 * * * *",
      "script": "node ~/agentic-sdlc/agents/kanban-bridge.mjs sync && node ~/agentic-sdlc/agents/agent-registry.mjs",
      "description": "Sync the SDLC task queue into the Hermes kanban board and refresh the agent registry, so the command-center dashboard shows live backlog + agent state. Idempotent.",
      "session": "isolated"
    },
    {
      "name": "pr-auto-review",
      "cron": "7,27,47 * * * *",
      "script": "node ~/agentic-sdlc/agents/pr-auto-review.mjs",
      "description": "Automated review-merge of agent/drain/* PRs: clean-worktree test hard gate + deterministic scope/safety scan + OpenRouter LLM review; merges safe green PRs (max 3/run), marks their queue tasks complete, comments-and-leaves-open everything else. Guardrail-touching diffs are never auto-merged.",
      "session": "isolated"
    }
  ]
}
