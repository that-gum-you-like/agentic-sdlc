# Agentic SDLC — Environment Variables
# Copy to .env and fill in the values you need.
# You only need keys for providers you actually use.

# ─── LLM Providers (set the ones you use) ───────────────────────────
# At least one is needed for model-manager health checks and LLM adapter scripts.
# Free tiers (no credit card): Groq, Gemini, Cerebras

ANTHROPIC_API_KEY=         # Claude models — https://console.anthropic.com/
OPENAI_API_KEY=            # GPT models — https://platform.openai.com/api-keys
GROQ_API_KEY=              # Groq-hosted models (free tier) — https://console.groq.com/keys
GEMINI_API_KEY=            # Google Gemini (free tier) — https://aistudio.google.com/apikey
CEREBRAS_API_KEY=          # Cerebras Inference (free tier) — https://cloud.cerebras.ai/
OLLAMA_HOST=               # Local Ollama — default: http://localhost:11434

# ─── Platform Integration (optional) ────────────────────────────────
# Only needed if using the Paperclip orchestration adapter.

PAPERCLIP_API_KEY=         # Paperclip control plane
PAPERCLIP_API_URL=         # Paperclip API endpoint
PAPERCLIP_COMPANY_ID=      # Paperclip company identifier

# ─── Runtime (set automatically by framework scripts) ───────────────
# These are set by worker.mjs and queue-drainer.mjs. You don't set them manually.

# AGENT=                   # Current agent name (set by worker.mjs)
# TASK_ID=                 # Current task ID (set by worker.mjs)
# SDLC_PROJECT_DIR=        # Override project directory detection
# HOME=                    # System home directory (set by OS)
